# FailSafe local development
NODE_ENV=development
STUDIO_WEB_PORT=3000
ORCHESTRATOR_API_PORT=4000
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
ORCHESTRATOR_API_BASE_URL=http://localhost:4000

# Leave disabled for launch/production. Set to 1 only when explicitly
# exercising Sample Lab compatibility routes in local smoke tests.
FAILSAFE_ENABLE_SAMPLE_DATA=0

# Optional reviewed Microsoft Foundry readiness checks.
# Leave live Foundry disabled unless running a reviewed local probe with `az`
# already installed and logged in. These values stay server-side only.
FAILSAFE_ENABLE_LIVE_FOUNDRY=0
# AZURE_FOUNDRY_PROJECT_ENDPOINT=
# AZURE_FOUNDRY_AGENT_ID=
# AZURE_TENANT_ID=
# AZURE_FOUNDRY_MODEL_DEPLOYMENT=

# Reserved for explicitly reviewed future integrations.
# Do not commit real secrets or live service endpoints.
# OPENAI_API_KEY=
# GITHUB_TOKEN=
# DATABASE_URL=
# REDIS_URL=
